root = true

[*.{js,jsx,ts,tsx,css,scss,html,json,yml,yaml}]
indent_style = space
indent_size = 2
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.sh]
indent_style = space
indent_size = 2

[app/api/**.ts]
indent_style = space
indent_size = 2

[app/web/**.{ts,tsx}]
indent_style = space
indent_size = 2

[packages/shared/**.ts]
indent_style = space
indent_size = 2
