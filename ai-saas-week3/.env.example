# 通用配置
NODE_ENV=development

# Web 前端
WEB_PORT=3000

# FastAPI 后端
BACKEND_PORT=8000
APP_NAME=AI SaaS API
APP_VERSION=1.0.0
DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_saas
REDIS_URL=redis://redis:6379/0
ALLOWED_ORIGINS=["*"]

# AI 服务

# Option A: 使用 OpenAI 兼容接口（如阿里云 DashScope）
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=

# Option B: 使用 Ollama 本地模型
# OLLAMA_MODEL=
# OLLAMA_BASE_URL=
